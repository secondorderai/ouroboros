{
  "model": {
    "provider": "openai",
    "name": "gpt-5.4"
  },
  "permissions": {
    "tier0": true,
    "tier1": true,
    "tier2": true,
    "tier3": false,
    "tier4": false
  },
  "skillDirectories": [
    "skills/core",
    "skills/generated"
  ],
  "memory": {
    "consolidationSchedule": "session-end"
  },
  "rsi": {
    "noveltyThreshold": 0.7,
    "autoReflect": true
  }
}
