{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "outDir": "dist",
    "composite": true
  },
  "include": [
    "src/main/**/*.ts",
    "src/shared/**/*.ts",
    "src/main/preload.ts",
    "scripts/**/*.ts",
    "electron.vite.config.ts"
  ]
}
