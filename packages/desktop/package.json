{
  "name": "@ouroboros/desktop",
  "version": "0.1.0",
  "description": "Ouroboros Desktop \u2014 Electron app for the self-improving AI agent",
  "type": "module",
  "private": true,
  "license": "MIT",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --config electron-builder.yml --dir",
    "build:vite": "electron-vite build",
    "preview": "electron-vite preview",
    "build:cli": "bash scripts/build-cli.sh",
    "build:mac": "electron-vite build && electron-builder --config electron-builder.yml --mac",
    "build:win": "electron-vite build && electron-builder --config electron-builder.yml --win",
    "build:dist": "electron-vite build && electron-builder --config electron-builder.yml",
    "test:e2e": "npx playwright test",
    "test:e2e:contracts": "npx playwright test tests/e2e/renderer-contract.spec.ts",
    "test:e2e:real": "npx playwright test tests/e2e/real-flows.spec.ts tests/e2e/main-process.spec.ts",
    "test:cdp:smoke": "bash scripts/electron-cdp-smoke.sh",
    "ts-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "echo 'No linter configured yet'"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "react-virtuoso": "^4.12.3",
    "zustand": "^5.0.3",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "rehype-highlight": "^7.0.1",
    "highlight.js": "^11.10.0",
    "fuse.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "@electron/notarize": "^2.5.0",
    "@playwright/test": "^1.49.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
