{
  "name": "@ouroboros/desktop",
  "version": "0.1.0",
  "description": "Ouroboros Desktop — Electron app for the self-improving AI agent",
  "author": "SecondOrder AI",
  "type": "module",
  "private": true,
  "license": "MIT",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "bun run build:cli && electron-vite dev",
    "build": "electron-vite build && electron-builder --config electron-builder.yml --dir",
    "build:vite": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "bun run build:cli && bun run build:vite && bun run preview",
    "build:cli": "bash scripts/build-cli.sh",
    "build:mac": "electron-vite build && electron-builder --config electron-builder.yml --mac --publish never",
    "build:win": "electron-vite build && electron-builder --config electron-builder.yml --win --publish never",
    "build:dist": "electron-vite build && electron-builder --config electron-builder.yml --publish never",
    "release": "electron-vite build && electron-builder --config electron-builder.yml --publish always",
    "test:e2e": "npx playwright test",
    "test:e2e:contracts": "npx playwright test tests/e2e/renderer-contract.spec.ts",
    "test:e2e:real": "npx playwright test tests/e2e/real-flows.spec.ts tests/e2e/main-process.spec.ts",
    "test:cdp:smoke": "bash scripts/electron-cdp-smoke.sh",
    "ts-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "echo 'No linter configured yet'"
  },
  "dependencies": {
    "electron-store": "^10.1.0",
    "electron-updater": "^6.8.3",
    "fuse.js": "^7.3.0",
    "highlight.js": "^11.11.1",
    "mermaid": "^11.14.0",
    "react-markdown": "^9.1.0",
    "react-virtuoso": "^4.18.6",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "41.5.0",
    "@electron/notarize": "^3.1.1",
    "@playwright/test": "^1.59.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
}
