                <mxCell id="e-rsi-flow-2" style="endArrow=classic;html=1;strokeColor=#9673a6;" parent="1" source="rsi-crystal" target="rsi-dream" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- Cross-section arrows -->
                <mxCell id="e-prompt-mem" value="reads" style="endArrow=classic;html=1;strokeColor=#d79b00;dashed=1;fontSize=10;exitX=0.2;exitY=1;exitDx=0;exitDy=0;entryX=0.2;entryY=0;entryDx=0;entryDy=0;" parent="1" source="core-prompt" target="mem-group" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e-prompt-skills" value="skill descriptions" style="endArrow=classic;html=1;strokeColor=#d79b00;dashed=1;fontSize=10;" parent="1" source="core-prompt" target="mem-skills" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e-children-trans" value="writes session" style="endArrow=classic;html=1;strokeColor=#d79b00;dashed=1;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="child-test" target="mem-trans" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e-react-rsi" value="post-turn" style="endArrow=classic;html=1;strokeColor=#9673a6;strokeWidth=1.5;fontSize=10;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;" parent="1" source="core-react" target="rsi-reflect" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1210" y="600"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="e-rsi-skills" value="writes skills" style="endArrow=classic;html=1;strokeColor=#9673a6;dashed=1;fontSize=10;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="rsi-crystal" target="mem-skills" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e-rsi-durable" value="updates durable" style="endArrow=classic;html=1;strokeColor=#9673a6;dashed=1;fontSize=10;exitX=0;exitY=0.7;exitDx=0;exitDy=0;entryX=1;entryY=0.7;entryDx=0;entryDy=0;" parent="1" source="rsi-dream" target="mem-durable" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="345" y="1100"/>
                        </Array>
                    </mxGeometry>
                </mxCell>

                <!-- ===================== FOOTER FLOW ===================== -->

                <mxCell id="flow-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf2;strokeColor=#d6b656;strokeWidth=1;dashed=1;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="80" y="1210" width="1640" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="flow-label" value="&lt;b&gt;Runtime flow — happy path&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#7d6608;" parent="1" vertex="1">
                    <mxGeometry x="100" y="1218" width="300" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="flow-text" value="&lt;b&gt;1.&lt;/b&gt; Desktop / CLI sends agent/run via JSON-RPC. The handler spins up the Root Agent with TranscriptStore + ModeManager + RSIOrchestrator + skill catalog.&lt;br&gt;&lt;b&gt;2.&lt;/b&gt; buildSystemPrompt assembles durable memory, checkpoint, working memory, skill descriptions, persona, and mode guidance; ReAct loop streams the LLM response.&lt;br&gt;&lt;b&gt;3.&lt;/b&gt; When the model emits a tool call, the parent registry dispatches it. spawn_agent forks a role-scoped child Agent; team_graph commits state to TaskGraphStore.&lt;br&gt;&lt;b&gt;4.&lt;/b&gt; Children run with bounded registries (read-only / test / worker with permission lease). Each returns a SubAgentResult; lifecycle events stream up via AgentEvent → bridgeAgentEvent → JSON-RPC notifications.&lt;br&gt;&lt;b&gt;5.&lt;/b&gt; On turn-complete, the RSIOrchestrator reflects on novelty, optionally crystallizes a new skill (validated then promoted/staged), and at session-end dreams to consolidate durable memory." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#444444;" parent="1" vertex="1">
                    <mxGeometry x="100" y="1240" width="1600" height="85" as="geometry"/>
                </mxCell>

            </root>
        </mxGraphModel>
    </diagram>
</mxfile>
