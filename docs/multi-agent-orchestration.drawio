                </mxCell>
                <mxCell id="subtitle" value="Root agent runs a ReAct loop, spawns role-scoped sub-agents, streams events to the desktop over JSON-RPC, and feeds outcomes back through memory + RSI." style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;" parent="1" vertex="1">
                    <mxGeometry x="280" y="58" width="1240" height="20" as="geometry"/>
                </mxCell>

                <!-- ===================== ROW 1: SURFACES ===================== -->

                <mxCell id="desktop-surface" value="&lt;b&gt;Desktop renderer + main process&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ChatView · RSIDrawer · ApprovalQueue · TeamGraphCanvas · subagent threads&lt;br&gt;Calls window.ouroboros.rpc(); subscribes to notifications&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=11;" parent="1" vertex="1">
