                <mxCell id="renderer-render" value="&lt;b&gt;Read-optimized chat UI&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;react-markdown + remark-gfm&lt;br&gt;rehype-highlight + Mermaid&lt;br&gt;react-virtuoso virtualized lists&lt;br&gt;Sandboxed artifact iframes (CSP)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" parent="1" vertex="1">
