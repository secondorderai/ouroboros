                </mxCell>
                <mxCell id="main-app" value="&lt;b&gt;index.ts + window.ts&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;App lifecycle&lt;br&gt;BrowserWindow creation&lt;br&gt;IPC registration&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" parent="1" vertex="1">
