                <mxCell id="desktop-flow" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffdf2;strokeColor=#d6b656;strokeWidth=1;dashed=1;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="575" width="720" height="125" as="geometry"/>
                </mxCell>
                <mxCell id="desktop-flow-label" value="&lt;b&gt;Desktop runtime flow&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#7d6608;" parent="1" vertex="1">
                    <mxGeometry x="85" y="585" width="180" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="desktop-flow-text" value="1. Renderer invokes typed preload APIs.&lt;br&gt;2. Main process forwards JSON-RPC to the CLI child over stdin/stdout.&lt;br&gt;3. CLI streams notifications back for text chunks, tool calls, completion, and errors.&lt;br&gt;4. Main process also handles platform-only actions such as file pickers and app updates." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#666666;" parent="1" vertex="1">
                    <mxGeometry x="85" y="610" width="680" height="75" as="geometry"/>
                </mxCell>

