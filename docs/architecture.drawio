                </mxCell>
                <mxCell id="desktop-note" value="Electron shell only. UI, orchestration, and native platform integration live here; agent intelligence stays in the CLI child process." style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#666666;" parent="1" vertex="1">
