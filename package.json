{
  "name": "ouroboros",
  "version": "0.1.0",
  "description": "A recursive self-improving AI agent",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "ouroboros": "dist/cli.js"
  },
  "scripts": {
    "dev": "bun run --watch src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target bun",
    "test": "bun test",
    "lint": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "bun run --bun tsc --noEmit"
  },
  "dependencies": {
    "ai": "^4.3.0",
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/openai": "^1.2.0",
    "better-sqlite3": "^11.8.0",
    "commander": "^13.1.0",
    "ink": "^5.2.0",
    "react": "^19.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.2.10",
    "@types/react": "^19.1.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0"
  }
}
