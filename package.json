{
  "name": "ouroboros",
  "version": "0.1.0",
  "description": "A recursive self-improving AI agent",
  "type": "module",
  "main": "dist/ouroboros",
  "bin": {
    "ouroboros": "dist/ouroboros"
  },
  "scripts": {
    "dev": "bun run --watch src/cli.ts",
    "build": "bun build --compile --minify --sourcemap ./src/cli.ts --outfile dist/ouroboros",
    "start": "./dist/ouroboros",
    "test": "bun test",
    "lint": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "ts-check": "bun run --bun tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.66",
    "@ai-sdk/openai": "3.0.50",
    "ai": "6.0.146",
    "better-sqlite3": "12.8.0",
    "commander": "14.0.3",
    "ink": "6.8.0",
    "react": "19.2.4",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/bun": "1.3.11",
    "@types/react": "19.2.14",
    "prettier": "3.8.1",
    "typescript": "6.0.2"
  }
}
